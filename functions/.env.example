# ─────────────────────────────────────────────────────────────────────────────
# LinguaBridge – Firebase Functions environment variables
# Copy this file to functions/.env and fill in your real values.
# functions/.env is gitignored and NEVER committed.
# ─────────────────────────────────────────────────────────────────────────────

# Oracle Autonomous Database (walletless / mTLS-less connection)
# Format: tcps://hostname:port/service_name
# Example: tcps://adb.eu-amsterdam-1.oraclecloud.com:1522/xxxxxxx_linguabridge_high.adb.oraclecloud.com
ORACLE_USER=ADMIN
ORACLE_PASSWORD=YourStrongPasswordHere
ORACLE_CONNECT_STRING=tcps://adb.<region>.oraclecloud.com:1522/<db_unique_name>_high.adb.oraclecloud.com

# Firebase Storage bucket (defaults to <projectId>.firebasestorage.app if omitted)
# FIREBASE_STORAGE_BUCKET=linguabridge-2574f.firebasestorage.app

# CORS origin for public intake endpoints (set to your deployed domain)
ALLOWED_ORIGIN=https://linguabridge.study
